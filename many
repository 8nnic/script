-- Tool Functions
local function GiveSword()
    -- Remove existing sword
    local existingSword = Character:FindFirstChild("ClassicSword")
    if existingSword then
        existingSword:Destroy()
    end
    
    -- Create sword
    local sword = Instance.new("Tool")
    sword.Name = "ClassicSword"
    sword.RequiresHandle = true
    
    local handle = Instance.new("Part")
    handle.Name = "Handle"
    handle.Size = Vector3.new(0.5, 4, 0.5)
    handle.BrickColor = BrickColor.new("Medium stone grey")
    handle.Material = Enum.Material.Metal
    handle.Parent = sword
    
    -- Sword blade
    local blade = Instance.new("Part")
    blade.Name = "Blade"
    blade.Size = Vector3.new(0.3, 3, 0.1)
    blade.BrickColor = BrickColor.new("Light stone grey")
    blade.Material = Enum.Material.Metal
    blade.Parent = handle
    
    local weld = Instance.new("Weld")
    weld.Part0 = handle
    weld.Part1 = blade
    weld.C0 = CFrame.new(0, 2, 0)
    weld.Parent = handle
    
    -- Sword guard
    local guard = Instance.new("Part")
    guard.Name = "Guard"
    guard.Size = Vector3.new(2, 0.2, 0.2)
    guard.BrickColor = BrickColor.new("Dark stone grey")
    guard.Material = Enum.Material.Metal
    guard.Parent = handle
    
    local guardWeld = Instance.new("Weld")
    guardWeld.Part0 = handle
    guardWeld.Part1 = guard
    guardWeld.C0 = CFrame.new(0, 0.5, 0)
    guardWeld.Parent = handle
    
    -- Damage script
    local damageScript = Instance.new("Script")
    damageScript.Source = [[
        local tool = script.Parent
        local damage = 25
        
        tool.Activated:Connect(function()
            local character = tool.Parent
            local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
            if not humanoidRootPart then return end
            
            local touchedParts = {}
            for _, part in pairs(workspace:GetPartBoundsInRadius(humanoidRootPart.Position, 10)) do
                local humanoid = part.Parent:FindFirstChild("Humanoid")
                if humanoid and part.Parent ~= character then
                    humanoid:TakeDamage(damage)
                end
            end
        end)
    ]]
    damageScript.Parent = sword
    
    sword.Parent = LocalPlayer.Backpack
    
    Rayfield:Notify({
       Title = "Sword Equipped",
       Content = "Classic sword added to inventory!",
       Duration = 3,
       Image = 4483362458,
    })
end

local RainbowCarpet = nil
local CarpetConnection = nil

local function GiveRainbowCarpet()
    -- Remove existing carpet
    if RainbowCarpet then
        RainbowCarpet:Destroy()
        if CarpetConnection then
            CarpetConnection:Disconnect()
        end
    end
    
    -- Create rainbow carpet
    local carpet = Instance.new("Part")
    carpet.Name = "RainbowCarpet"
    carpet.Size = Vector3.new(6, 0.5, 6)
    carpet.Material = Enum.Material.Neon
    carpet.Anchored = true
    carpet.CanCollide = true
    carpet.TopSurface = Enum.SurfaceType.Smooth
    carpet.BottomSurface = Enum.SurfaceType.Smooth
    
    -- Add pattern mesh
    local mesh = Instance.new("BlockMesh")
    mesh.Scale = Vector3.new(1, 0.2, 1)
    mesh.Parent = carpet
    
    carpet.Parent = workspace
    RainbowCarpet = carpet
    
    -- Rainbow effect
    local hue = 0
    CarpetConnection = RunService.Heartbeat:Connect(function()
        if not RainbowCarpet or not HumanoidRootPart then return end
        
        -- Update position to follow player
        RainbowCarpet.CFrame = CFrame.new(HumanoidRootPart.Position - Vector3.new(0, 3.5, 0))
        
        -- Rainbow color
        hue = (hue + 1) % 360
        RainbowCarpet.Color = Color3.fromHSV(hue / 360, 1, 1)
    end)
    
    Rayfield:Notify({
       Title = "Rainbow Carpet Spawned",
       Content = "Flying carpet following you!",
       Duration = 3,
       Image = 4483362458,
    })
end

local function RemoveRainbowCarpet()
    if RainbowCarpet then
        RainbowCarpet:Destroy()
        RainbowCarpet = nil
    end
    if CarpetConnection then
        CarpetConnection:Disconnect()
        CarpetConnection = nil
    end
    
    Rayfield:Notify({
       Title = "Carpet Removed",
       Content = "Rainbow carpet destroyed!",
       Duration = 3,
       Image = 4483362458,
    })
end

