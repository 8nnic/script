    HumanoidRootPart = newChar:WaitForChild("HumanoidRootPart")
    
    -- Reapply jump power
    wait(0.1)
    SetJumpPower(CurrentJumpPower)
    Humanoid.WalkSpeed = CurrentWalkSpeed
    
    -- Reapply noclip if it was enabled
    if NoclipEnabled then
        NoclipEnabled = false
    end
    
    -- Reapply fly if it was enabled
    if FlyEnabled then
        FlyEnabled = false
    end
end)

