-- Detect if game uses JumpPower or JumpHeight
local function SetJumpPower(value)
    if not Humanoid then return end
    
    -- Check if the game uses the new JumpHeight system
    if Humanoid.UseJumpPower == false then
        -- Convert JumpPower to JumpHeight (approximate conversion)
        Humanoid.JumpHeight = value / 10
    else
        -- Use classic JumpPower
        Humanoid.UseJumpPower = true
        Humanoid.JumpPower = value
    end
end

