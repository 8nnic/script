    titleLabel.Text = "Coordinates"
    titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    titleLabel.Font = Enum.Font.SourceSansBold
    titleLabel.TextSize = 18
    titleLabel.Parent = frame
    
    -- X Coordinate
    local xLabel = Instance.new("TextLabel")
    xLabel.Size = UDim2.new(1, -10, 0, 20)
    xLabel.Position = UDim2.new(0, 5, 0, 35)
    xLabel.BackgroundTransparency = 1
    xLabel.Text = "X: 0"
    xLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    xLabel.Font = Enum.Font.SourceSans
    xLabel.TextSize = 16
    xLabel.TextXAlignment = Enum.TextXAlignment.Left
    xLabel.Parent = frame
    
    -- Y Coordinate
    local yLabel = Instance.new("TextLabel")
    yLabel.Size = UDim2.new(1, -10, 0, 20)
    yLabel.Position = UDim2.new(0, 5, 0, 55)
    yLabel.BackgroundTransparency = 1
    yLabel.Text = "Y: 0"
    yLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    yLabel.Font = Enum.Font.SourceSans
    yLabel.TextSize = 16
    yLabel.TextXAlignment = Enum.TextXAlignment.Left
    yLabel.Parent = frame
    
    -- Z Coordinate
    local zLabel = Instance.new("TextLabel")
    zLabel.Size = UDim2.new(1, -10, 0, 20)
    zLabel.Position = UDim2.new(0, 5, 0, 75)
    zLabel.BackgroundTransparency = 1
    zLabel.Text = "Z: 0"
    zLabel.TextColor3 = Color3.fromRGB(100, 100, 255)
    zLabel.Font = Enum.Font.SourceSans
    zLabel.TextSize = 16
    zLabel.TextXAlignment = Enum.TextXAlignment.Left
    zLabel.Parent = frame
    
    CoordinateGui = screenGui
    
    -- Update coordinates
    CoordinateConnection = RunService.Heartbeat:Connect(function()
        if not CoordinateEnabled or not HumanoidRootPart then return end
        
        local pos = HumanoidRootPart.Position
        xLabel.Text = string.format("X: %.2f", pos.X)
        yLabel.Text = string.format("Y: %.2f", pos.Y)
        zLabel.Text = string.format("Z: %.2f", pos.Z)
    end)
end

local function RemoveCoordinateGui()
    if CoordinateGui then
        CoordinateGui:Destroy()
        CoordinateGui = nil
    end
    if CoordinateConnection then
        CoordinateConnection:Disconnect()
        CoordinateConnection = nil
    end
end

