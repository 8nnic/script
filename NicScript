-- Enhanced Aimbot Functions
local function GetClosestPlayerToCursor()
    local closestPlayer = nil
    local shortestDistance = AimbotFOV
    local camera = workspace.CurrentCamera
    local mousePos = UserInputService:GetMouseLocation()
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local character = player.Character
            local humanoid = character:FindFirstChild("Humanoid")
            local head = character:FindFirstChild("Head")
            
            if humanoid and humanoid.Health > 0 and head then
                -- Team check
                if AimbotTeamCheck and player.Team == LocalPlayer.Team then
                    continue
                end
                
                -- Calculate screen position
                local headPos, onScreen = camera:WorldToViewportPoint(head.Position)
                
                if onScreen then
                    local screenPos = Vector2.new(headPos.X, headPos.Y)
                    local distanceFromMouse = (screenPos - mousePos).Magnitude
                    local distanceFrom3D = (head.Position - HumanoidRootPart.Position).Magnitude
                    
                    -- Check if within FOV and closer than previous
                    if distanceFrom3D < AimbotFOV and distanceFromMouse < shortestDistance then
                        closestPlayer = player
                        shortestDistance = distanceFromMouse
                    end
                end
            end
        end
    end
    
    return closestPlayer
end

local function EnableAimbot()
    AimbotConnection = RunService.RenderStepped:Connect(function()
        if not AimbotEnabled then return end
        
        local target = GetClosestPlayerToCursor()
        
        if target and target.Character then
            local head = target.Character:FindFirstChild("Head")
            
            if head then
                local camera = workspace.CurrentCamera
                local targetCFrame = CFrame.new(camera.CFrame.Position, head.Position)
                
                -- Smooth aiming
                if AimbotSmoothness > 0 then
                    camera.CFrame = camera.CFrame:Lerp(targetCFrame, 1 - AimbotSmoothness)
                else
                    camera.CFrame = targetCFrame
                end
            end
        end
    end)
end

local function DisableAimbot()
    if AimbotConnection then
        AimbotConnection:Disconnect()
        AimbotConnection = nil
    end
end

