-- TAB 2: PLAYER CARDS CHECKER
-- ========================================
local TabCards = Window:CreateTab("🃏 Player Cards", 4483362458)
local SectionCards = TabCards:CreateSection("Check Other Players' Cards")

local selectedPlayer = nil

-- Function to get all players with status
local function getAllPlayers()
    local dropdownOptions = {}

    for _, player in ipairs(Players:GetPlayers()) do
        local playerModel = workspace:FindFirstChild(player.Name)
        if playerModel then
            local humanoid = playerModel:FindFirstChildOfClass("Humanoid")
            if humanoid then
                local playerStatus = player.Name
                if humanoid.Health <= 0 then
                    playerStatus = player.Name .. " - Dead"
                end
                table.insert(dropdownOptions, playerStatus)
            end
        end
    end

    return dropdownOptions
end

-- Create player dropdown
local dropdownOptions = getAllPlayers()
local Dropdown = TabCards:CreateDropdown({
    Name = "Select Player",
    Options = dropdownOptions,
    CurrentOption = {},
    MultipleOptions = false,
    Flag = "PlayerDropdown",
    Callback = function(Options)
        selectedPlayer = Options[1]
    end,
})

-- Update dropdown when players join
Players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(function(character)
        local humanoid = character:WaitForChild("Humanoid")
        humanoid:GetPropertyChangedSignal("Health"):Connect(function()
            Dropdown:Set(getAllPlayers())
        end)
    end)
end)

-- Update dropdown when players leave
Players.PlayerRemoving:Connect(function()
    Dropdown:Set(getAllPlayers())
end)

-- Periodically update dropdown
task.spawn(function()
    while true do
        Dropdown:Set(getAllPlayers())
        task.wait(5)
    end
end)

-- Check Cards Button
local Button = TabCards:CreateButton({
    Name = "Check Player's Cards",
    Callback = function()
        if selectedPlayer then
            -- Remove " - Dead" suffix if present
            local cleanPlayerName = selectedPlayer:gsub(" %- Dead", "")
            local playerModel = workspace:FindFirstChild(cleanPlayerName)
            
            if playerModel then
                local humanoid = playerModel:FindFirstChildOfClass("Humanoid")
                if humanoid and humanoid.Health <= 0 then
                    sendNotification("Player Status", string.format("%s is dead.", cleanPlayerName), 5, nil)
                    return
                end

                local cardsFolder = playerModel:FindFirstChild("Cards")
                if cardsFolder and cardsFolder:IsA("Folder") then
                    local cardNames = {}
                    for _, folder in ipairs(cardsFolder:GetChildren()) do
                        if folder:IsA("Folder") then
                            table.insert(cardNames, folder.Name)
                        end
                    end
                    
                    if #cardNames > 0 then
                        sendNotification("Cards Found", string.format("%s's Cards: %s", cleanPlayerName, table.concat(cardNames, ", ")), 7, nil)
                    else
                        sendNotification("No Cards", string.format("%s has no cards.", cleanPlayerName), 5, nil)
                    end
                else
                    sendNotification("Missing Cards Folder", cleanPlayerName .. " does not have a Cards folder.", 5, nil)
                end
            else
                sendNotification("Error", "Player model not found in Workspace.", 5, nil)
            end
        else
            sendNotification("Error", "No player selected in the dropdown.", 5, nil)
        end
    end,
})

